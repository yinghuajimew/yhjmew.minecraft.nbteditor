<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded">

    <!-- 顶部彩色头部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_header"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp">

        <ImageView
        android:id="@+id/in_app_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_launcher"
            android:scaleType="centerCrop"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0.4"
                android:textColor="#E0E0E0"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 关于项（点击展开） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_about_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="!"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_green"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/about_header"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_about_expand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="#999999"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_about_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:paddingTop="0dp"
            android:textColor="#666666"
            android:textSize="14sp"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginStart="56dp" />
    </LinearLayout>

    <!-- 【设置项】点击展开四个选项 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_settings_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="⚙"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"
                android:background="@drawable/bg_circle_blue"
                android:layout_marginEnd="16dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/settings_header"
                android:textColor="#333333"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tv_settings_expand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▼"
                android:textColor="#999999"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 【设置内容】四个选项 -->
        <LinearLayout
            android:id="@+id/layout_settings_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="0dp"
            android:visibility="gone">

            <!-- 1. 多线程 -->
            <CheckBox
                android:id="@+id/cb_dialog_multithread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/box_enable_multi_thread_acceleration"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- 2. Shizuku -->
            <CheckBox
                android:id="@+id/cb_dialog_shizuku"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/box_use_shizuku"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- 3. 日夜模式 -->
            <Button
                android:id="@+id/btn_dialog_theme"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="🌙 切换到夜间模式"
                android:textColor="#FF9800"
                android:textSize="14sp"
                android:gravity="start|center_vertical"
                android:paddingStart="4dp"
                android:layout_marginBottom="8dp" />

            <!-- 4. 语言 -->
            <Button
                android:id="@+id/btn_dialog_lang"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Switch to English"
                android:textColor="#2196F3"
                android:textSize="14sp"
                android:gravity="start|center_vertical"
                android:paddingStart="4dp" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>