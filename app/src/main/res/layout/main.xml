<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- ========================================= -->
    <!-- [层级 1] 主界面内容 (原 LinearLayout) -->
    <!-- ========================================= -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 全屏模式下的顶栏 (功能齐全版) -->
        <LinearLayout
            android:id="@+id/layout_fullscreen_bar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:visibility="gone"
            android:background="#2196F3"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center_vertical"
            android:elevation="4dp">

            <!-- 1. 返回 -->
            <Button
                android:id="@+id/btn_exit_fullscreen"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="←"
                android:textColor="#FFFFFF"
                android:background="#00000000"
                android:textSize="24sp"
                android:textStyle="bold"
                android:padding="0dp"
                android:gravity="center" />

            <!-- 2. 路径显示 -->
            <TextView
                android:id="@+id/tv_fullscreen_path"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="@string/path_prefix"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="center_vertical|start"
                android:paddingStart="4dp"
                android:ellipsize="middle"
                android:singleLine="true" />

            <!-- === 右侧功能区 (紧凑排列) === -->

            <!-- 3. 树状图切换 (绿) -->
            <Button
                android:id="@+id/btn_fullscreen_tree"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="🌲"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:padding="0dp"
                android:gravity="center"
                android:layout_marginEnd="4dp" />

            <!-- 4. 显示设置 (橙) -->
            <Button
                android:id="@+id/btn_fullscreen_view"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="👁"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:padding="0dp"
                android:gravity="center"
                android:layout_marginEnd="4dp" />

            <!-- 5. 搜索 (蓝) -->
            <Button
                android:id="@+id/btn_fullscreen_search"
                android:layout_width="40dp"
                android:layout_height="36dp"
                android:text="🔍"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:padding="0dp"
                android:gravity="center"
                android:layout_marginEnd="0dp" />

            <!-- 6. 菜单 (透明) -->
            <Button
                android:id="@+id/btn_fullscreen_menu"
                android:layout_width="36dp"
                android:layout_height="40dp"
                android:text="⋮"
                android:textColor="#FFFFFF"
                android:background="#00000000"
                android:textSize="22sp"
                android:padding="0dp"
                android:gravity="center" />

        </LinearLayout>

        <!-- 正常 UI (紧凑版) -->
        <LinearLayout
            android:id="@+id/layout_normal_ui"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 1. 标题栏区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <!-- 减小底部间距 -->

                <!-- [修改] 侧边栏触发按钮 (汉堡菜单) -->
                <!-- 增加 elevation 确保浮在顶层 -->
                <!-- 增加 clickable 和 focusable 属性 -->
                <Button
                    android:id="@+id/btn_open_drawer"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:text="☰"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:background="#00000000"
                    android:gravity="center"
                    android:padding="0dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="10dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- 标题 -->
                <!-- [修改] 动态标题区 (垂直布局：上面名字，下面种子) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp">

                    <!-- 大标题：显示 APP名 或 存档名 -->
                    <TextView
                        android:id="@+id/tv_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <!-- 小标题：显示种子 (默认隐藏) -->
                    <TextView
                        android:id="@+id/tv_info_seed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seed: -"
                        android:textSize="10sp"
                        android:textColor="#757575"
                        android:visibility="gone"
                        android:textIsSelectable="true" />
                </LinearLayout>

                <!-- 右侧按钮组 (更紧凑) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <!-- 第一行 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <Button
                            android:id="@+id/btn_clear_cache"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:text="@string/btn_clean_cache"
                            android:textSize="11sp"
                            android:backgroundTint="#607D8B"
                            android:textColor="#FFFFFF"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:layout_marginEnd="4dp" />
                        <Button
                            android:id="@+id/btn_check_permission"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:text="@string/btn_check_perm"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#607D8B"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp" />
                    </LinearLayout>

                    <!-- 第二行 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">
                        <Button
                            android:id="@+id/btn_switch_path"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:text="@string/btn_switch_path"
                            android:textSize="11sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#607D8B"
                            android:paddingTop="0dp"
                            android:paddingBottom="0dp"
                            android:layout_marginEnd="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 2. 存档选择框 (高度减小) -->
            <EditText
                android:id="@+id/et_world_name"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:hint="@string/hint_select_world"
                android:background="#FFFFFF"
                android:padding="5dp"
                android:gravity="center"
                android:layout_marginBottom="6dp"
                android:focusable="false"
                android:clickable="true"
                android:textSize="14sp" />

            <!-- 3. 核心按钮矩阵 (高度减小，间距减小) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="4dp">

                <!-- 第一行 加载/保存 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">
                    <Button
                        android:id="@+id/btn_copy"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="@string/btn_load"
                        android:textSize="13sp"
                        android:backgroundTint="#2196F3"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/btn_save"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="@string/btn_save"
                        android:textSize="13sp"
                        android:backgroundTint="#F44336"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <!-- 第二行 玩家/恢复 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/btn_edit_player"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="@string/btn_edit_player"
                        android:textSize="13sp"
                        android:backgroundTint="#673AB7"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="4dp" />
                    <Button
                        android:id="@+id/btn_backup_history"
                        android:layout_width="0dp"
                        android:layout_height="38dp"
                        android:layout_weight="1"
                        android:text="@string/btn_restore"
                        android:textSize="13sp"
                        android:backgroundTint="#4CAF50"
                        android:textColor="#FFFFFF"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 4. 重新解析 (变扁) -->
            <Button
                android:id="@+id/btn_parse"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:text="@string/btn_reparse"
                android:textSize="12sp"
                android:backgroundTint="#9E9E9E"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"
                android:padding="0dp" />

        </LinearLayout>

        <!-- 3. 数据编辑标题栏 (工具栏) -->
        <LinearLayout
            android:id="@+id/layout_editor_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="5dp"
            android:layout_marginTop="5dp">

            <TextView
                android:id="@+id/tv_current_path"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_editor"
                android:textSize="12sp"
                android:textColor="#757575" />

            <!-- [新增] 树状图模式 -->
            <Button
                android:id="@+id/btn_tree_mode"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:text="🌲"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="5dp"
                android:padding="0dp" />

            <!-- [新增] 显示选项 -->
            <Button
                android:id="@+id/btn_view_options"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:text="👁"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginEnd="5dp"
                android:padding="0dp" />
            <!-- === [新增] 搜索按钮 === -->
            <Button
                android:id="@+id/btn_search_nbt"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:text="🔍"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:layout_marginEnd="5dp"
                android:padding="0dp" />
            <!-- 进入全屏 -->
            <Button
                android:id="@+id/btn_go_fullscreen"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/btn_fullscreen"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:padding="0dp" />
        </LinearLayout>

        <!-- 4. 主列表 -->
        <ListView
            android:id="@+id/lv_nbt_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:divider="#EEEEEE"
            android:dividerHeight="1dp"
            android:padding="5dp"
            android:layout_marginTop="5dp" />

    </LinearLayout>


<!-- 侧边栏容器 -->
<LinearLayout
    android:id="@+id/custom_sidebar_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:visibility="gone">

    <!-- 侧边栏本体 -->
    <LinearLayout
        android:id="@+id/sidebar_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="16dp">

        <!-- 【头部区域】固定高度，不滚动 -->
        <LinearLayout
            android:id="@+id/sidebar_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#4CAF50"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">

            <!-- 左侧：应用图标 -->
            <ImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_launcher"
                android:scaleType="centerCrop"
                android:layout_marginEnd="12dp" />

            <!-- 右侧：名称区域 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_sidebar_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_sidebar_author"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/author_name"
                    android:textColor="#E8F5E9"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 【按钮列表】可滚动 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/layout_sidebar_items"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <Button
                    android:id="@+id/btn_online_players"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_edit_online_players"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:background="#2196F3"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_map_nbt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_edit_map_data"
                    android:background="#FF9800"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_village_nbt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_edit_village_data"
                    android:background="#795548"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_open_any_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_open_nbt_by_name_dvanced"
                    android:background="#607D8B"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btn_global_nbt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_global_system_data"
                    android:background="#673AB7"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- 遮罩 -->
    <View
        android:id="@+id/view_mask"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#80000000"
        android:clickable="true" />

</LinearLayout>

</FrameLayout>